import React, { useState, useEffect } from 'react';
import { motion } from 'framer-motion';
import { RotateCcw } from 'lucide-react';
import { useAppStore } from '../../store';
import { translations } from '../../translations';
import { playSound } from '../../utils/audio';

const COLORS = [
  { id: 0, color: 'bg-red-500', active: 'bg-red-300 ring-4 ring-red-400' },
  { id: 1, color: 'bg-blue-500', active: 'bg-blue-300 ring-4 ring-blue-400' },
  { id: 2, color: 'bg-green-500', active: 'bg-green-300 ring-4 ring-green-400' },
  { id: 3, color: 'bg-yellow-500', active: 'bg-yellow-300 ring-4 ring-yellow-400' }
];

export default function SimonSays() {
  const { language } = useAppStore();
  const t = translations[language];
  
  const [sequence, setSequence] = useState<number[]>([]);
  const [playerStep, setPlayerStep] = useState(0);
  const [isPlaying, setIsPlaying] = useState(false);
  const [activeColor, setActiveColor] = useState<number | null>(null);
  const [gameOver, setGameOver] = useState(false);
  const [score, setScore] = useState(0);

  const startSequence = (newSeq: number[]) => {
    setIsPlaying(true);
    let i = 0;
    const interval = setInterval(() => {
      setActiveColor(newSeq[i]);
      playSound('pop');
      setTimeout(() => setActiveColor(null), 300);
      i++;
      if (i >= newSeq.length) {
        clearInterval(interval);
        setIsPlaying(false);
      }
    }, 600);
  };

  const addStep = () => {
    const nextColor = Math.floor(Math.random() * 4);
    const newSeq = [...sequence, nextColor];
    setSequence(newSeq);
    setPlayerStep(0);
    setTimeout(() => startSequence(newSeq), 500);
  };

  const handleColorClick = (colorId: number) => {
    if (isPlaying || gameOver || sequence.length === 0) return;
    
    playSound('pop');
    setActiveColor(colorId);
    setTimeout(() => setActiveColor(null), 200);

    if (colorId === sequence[playerStep]) {
      if (playerStep === sequence.length - 1) {
        setScore(s => s + 1);
        setIsPlaying(true);
        setTimeout(addStep, 500);
      } else {
        setPlayerStep(s => s + 1);
      }
    } else {
      playSound('lose');
      setGameOver(true);
    }
  };

  const start = () => {
    playSound('click');
    setScore(0);
    setGameOver(false);
    setSequence([]);
    setTimeout(() => {
      const first = Math.floor(Math.random() * 4);
      setSequence([first]);
      startSequence([first]);
    }, 500);
  };

  return (
    <div className="flex flex-col items-center w-full max-w-[320px]">
      <div className="w-full flex justify-between items-center mb-6 px-4">
        <span className="text-gray-500 font-bold uppercase tracking-wider">Score: {score}</span>
      </div>

      <div className="grid grid-cols-2 gap-4 w-[240px] mb-8">
        {COLORS.map(c => (
          <motion.button
            key={c.id}
            whileTap={{ scale: isPlaying || gameOver ? 1 : 0.9 }}
            onClick={() => handleColorClick(c.id)}
            className={`aspect-square rounded-full transition-all duration-200 ${
              activeColor === c.id ? c.active + ' scale-110 shadow-lg' : c.color + ' opacity-80 hover:opacity-100 shadow-sm'
            }`}
          />
        ))}
      </div>

      <div className="h-12 mb-6 flex items-center justify-center">
        {gameOver && (
          <motion.div initial={{opacity:0, scale:0.5}} animate={{opacity:1, scale:1}} className="text-center px-6 py-2 bg-red-100 dark:bg-red-900/30 rounded-full flex flex-col">
            <h3 className="text-lg font-bold text-red-600 dark:text-red-400">{t.youLose}</h3>
          </motion.div>
        )}
      </div>

      <button onClick={start} className="flex items-center gap-2 px-8 py-4 bg-ikyro-blue text-white font-bold rounded-2xl active:scale-95 transition-transform shadow-lg shadow-blue-500/30">
        <RotateCcw className="w-5 h-5" />
        {t.playNow}
      </button>
    </div>
  );
}
